{
  "name": "friendy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "agent:terminal": "tsx src/relationship/transports/terminalTransport.ts",
    "agent:spectrum": "tsx src/relationship/transports/spectrumTransport.ts",
    "agent:friendy": "tsx src/relationship/runtime/friendyRuntimeCli.ts",
    "agent:friendy:local-api": "tsx src/relationship/onboardingLocalApi.ts",
    "agent:friendy:check": "tsx src/relationship/runtime/friendyRuntimeCheck.ts",
    "build:macos-sensor": "node scripts/build-macos-sensor.mjs",
    "doctor:macos-sensor": "tsx src/relationship/runtime/macosSensorDoctor.ts",
    "doctor:friendy": "tsx src/relationship/runtime/friendyDoctor.ts",
    "friendy:stack-status": "bash scripts/friendy-stack-status.sh",
    "check:macos-sensor-fixture": "tsx src/relationship/runtime/macosSensorFixtureCheck.ts",
    "eval:agent": "tsx src/relationship/evals/agentEvalCli.ts",
    "check:mac-mvp-demo": "tsx src/relationship/evals/macMvpDemoCheck.ts",
    "check:mac-mvp-e2e-state": "tsx src/relationship/evals/macMvpE2eStateCheck.ts",
    "check:imessage-e2e": "tsx src/relationship/transports/imessageE2eFlow.ts",
    "ingest:check": "tsx src/relationship/ingestion/ingestCheck.ts",
    "ingest:local:check": "tsx src/relationship/ingestion/localCheckCli.ts",
    "ingest:contacts:smoke": "tsx src/relationship/contacts/contactsSmokeCli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chrono-node": "^2.9.1",
    "dotenv": "^17.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "spectrum-ts": "^1.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
